# Copie ce fichier en .env (a la racine du projet) et renseigne ta cle.
# Le fichier .env est ignore par git (voir .gitignore) : ta cle reste locale.
#
# Obtenir une cle Gemini : https://aistudio.google.com/apikey
GEMINI_API_KEY=your_api_key_here

# Optionnel : modele Gemini a utiliser (defaut : gemini-2.5-flash).
# Note : gemini-2.0-flash n'a plus de quota gratuit (HTTP 429, limit: 0).
# GEMINI_MODEL=gemini-2.5-flash
